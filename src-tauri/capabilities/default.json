{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "MiniMarkdown desktop permissions",
  "windows": ["main", "doc-*"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "process:allow-restart",
    "updater:default",
    "fs:default",
    "fs:read-files",
    "fs:write-files",
    "fs:read-meta",
    "fs:allow-stat",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**/*" },
        { "path": "$DOCUMENT/**/*" },
        { "path": "$DESKTOP/**/*" },
        { "path": "$DOWNLOAD/**/*" }
      ]
    }
  ]
}
